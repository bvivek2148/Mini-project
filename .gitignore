# ═══════════════════════════════════════════════════════════════
# RANSOM-TRAP PROJECT .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# ── Virtual Environment ──────────────────────────────────────
venv/
.venv/
env/

# ── Config Secrets (contains API tokens & passwords) ─────────
ransom_trap/config/config.yaml

# ── Agent Logs & Data ────────────────────────────────────────
ransom_trap/logs/
ransom_trap/data/
alerts.jsonl

# ── Test Artifacts ───────────────────────────────────────────
test_files/**/*.bak
test_files/**/standard_dummy_doc_*

# ── Environment Variables ────────────────────────────────────
.env
.env.local
.env.*.local

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
